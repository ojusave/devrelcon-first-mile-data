{
  "name": "devrelcon-first-mile-data",
  "version": "1.0.0",
  "description": "Source-grounded reconstructions of first-mile developer journeys across developer platforms, with an interactive onboarding-intelligence web service.",
  "type": "module",
  "private": true,
  "scripts": {
    "validate": "node validate-records.mjs",
    "build": "node build-all.mjs",
    "check": "node build-all.mjs --check",
    "test": "node tests/regression.mjs",
    "site": "node scripts/build-site.mjs",
    "build:data": "node scripts/build-site.mjs",
    "build:app": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "npm run build:app && node dist/server.js",
    "test:app": "npm run build:app && node --test tests/app/*.test.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
